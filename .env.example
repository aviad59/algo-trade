# algo-trade configuration
# Copy this file to `.env` at the repository root and edit values there.
# Shell exports override `.env` (useful in CI).

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# LLM models (empty = use defaults below, or ALGO_TRADE_LLM_MODEL for both)
# -----------------------------------------------------------------------------
ALGO_TRADE_LLM_MODEL=
ALGO_TRADE_EXTRACTOR_MODEL=
ALGO_TRADE_RECOMMENDER_MODEL=
ALGO_TRADE_DEFAULT_EXTRACTOR_MODEL=claude-opus-4-7
ALGO_TRADE_DEFAULT_RECOMMENDER_MODEL=claude-opus-4-7

# -----------------------------------------------------------------------------
# Extractor (Agent #1) tuning
# -----------------------------------------------------------------------------
ALGO_TRADE_EXTRACTOR_MAX_TOKENS=16000
ALGO_TRADE_EXTRACTOR_EFFORT=high

# -----------------------------------------------------------------------------
# Recommender (Agent #2) tuning
# -----------------------------------------------------------------------------
ALGO_TRADE_RECOMMENDER_MAX_TOKENS=8000
ALGO_TRADE_RECOMMENDER_EFFORT=high
ALGO_TRADE_RECOMMENDER_MAX_EXTRACTIONS=100

# -----------------------------------------------------------------------------
# API server (algo-trade-api)
# -----------------------------------------------------------------------------
ALGO_TRADE_API_HOST=0.0.0.0
ALGO_TRADE_API_PORT=8000
ALGO_TRADE_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
ALGO_TRADE_RANKING_MODE=rules

# -----------------------------------------------------------------------------
# Data paths (relative paths resolve from repo root)
# -----------------------------------------------------------------------------
ALGO_TRADE_BUFFER_PATH=data/buffer.sqlite
ALGO_TRADE_UNIVERSE_DIR=backend/universe

# Forecast window (ISO dates; leave empty for dynamic defaults)
ALGO_TRADE_FORECAST_SINCE=
ALGO_TRADE_FORECAST_UNTIL=

# -----------------------------------------------------------------------------
# Buy/sell timer
# -----------------------------------------------------------------------------
ALGO_TRADE_TIMER_LOOKAHEAD_MONTHS=3
ALGO_TRADE_TIMER_BUY_THRESHOLD=0.0

# -----------------------------------------------------------------------------
# SEC fetch + extract CLI (algo-trade-extract)
# -----------------------------------------------------------------------------
ALGO_TRADE_SEC_IDENTITY=
ALGO_TRADE_EXTRACT_FORM=10-K
ALGO_TRADE_EXTRACT_LIMIT=1

# -----------------------------------------------------------------------------
# Frontend (Vite — loaded from repo root via vite.config.ts envDir)
# -----------------------------------------------------------------------------
VITE_API_BASE=/mock/v1
VITE_DATA_SOURCE=mock
