{
  "name": "algo-trade-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run sync-mock",
    "dev": "vite",
    "prebuild": "npm run sync-mock",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
